# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_MODE=sandbox

# ── Email via Gmail SMTP ──────────────────────────────────────────────────────
# Setup: myaccount.google.com → Security → 2-Step Verification → App passwords
GMAIL_USER=doctor@gmail.com
GMAIL_APP_PASSWORD=                        # 16-char app password (no spaces)
GMAIL_FROM=Dr. Smith <doctor@gmail.com>    # Display name shown in patient inbox

# ── Clinic details (used in email templates) ──────────────────────────────────
CLINIC_NAME=Dr. Smith Medical Clinic
CLINIC_ADDRESS=123 Medical Center Dr, Suite 200, New York, NY 10001
CLINIC_PHONE=+1 (555) 123-4567
CLINIC_MAPS_URL=                           # Optional: Google Maps share link for "Get Directions" button

# ── Cron security (cron-job.org) ──────────────────────────────────────────────
# Setup: cron-job.org → New Cronjob → URL: https://your-domain.com/api/cron/reminders
#   Schedule: every 1 minute  |  Method: GET
#   Headers: Authorization = Bearer <your-secret>
CRON_SECRET=                               # Any random secret string — paste the same value in cron-job.org header

# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DOCTOR_EMAIL=doctor@gmail.com
DOCTOR_TIMEZONE=Asia/Kolkata
