# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── WhatsApp via Fonnte ────────────────────────────────────────────────────────
# No business registration needed. Setup steps:
#   1. Go to https://fonnte.com and create a free account
#   2. Add a device → scan QR code with the doctor's WhatsApp (personal or WhatsApp Business)
#   3. Copy the device token from the Fonnte dashboard → paste below
# Patients will receive messages FROM the doctor's WhatsApp number.
FONNTE_TOKEN=              # Device token from Fonnte dashboard

# ── Email via Gmail API (OAuth2) ───────────────────────────────────────────────
# Setup: Google Cloud Console → APIs → Gmail API → OAuth2 credentials
# Then run the one-time OAuth flow to get a refresh token (see README)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_FROM=Doctor Name <doctor@gmail.com>   # Display name + Gmail address

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_MODE=sandbox

# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DOCTOR_EMAIL=doctor@gmail.com
DOCTOR_PHONE=+910000000000   # Doctor's WhatsApp number (with country code, e.g. +919876543210)
# IANA timezone name for the doctor's clinic location. All appointment times and email
# notifications will use this timezone. Examples:
#   Asia/Kolkata       → IST (India)
#   America/New_York   → EST/EDT (US East Coast)
#   America/Chicago    → CST/CDT (US Central)
#   America/Los_Angeles → PST/PDT (US West Coast)
#   Europe/London      → GMT/BST (UK)
#   Europe/Paris       → CET/CEST (Central Europe)
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
DOCTOR_TIMEZONE=Asia/Kolkata

# ── Cron security (optional but recommended on Vercel) ────────────────────────
CRON_SECRET=                 # Any random secret string; add to Vercel cron headers too
